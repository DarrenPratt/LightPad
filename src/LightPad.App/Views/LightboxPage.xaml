<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:LightPad.App.ViewModels"
             x:Class="LightPad.App.Views.LightboxPage"
             x:DataType="viewModels:LightboxViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">
    <Grid>
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnLightSurfaceTapped" />
        </Grid.GestureRecognizers>

        <BoxView Color="{Binding LightColor}" />
        <BoxView Color="Black"
                 Opacity="{Binding BrightnessOverlayOpacity}"
                 InputTransparent="True" />

        <Border IsVisible="{Binding IsLockedHintVisible}"
                BackgroundColor="#BF101010"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 26"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Padding="22,16"
                InputTransparent="True">
            <Label Text="Locked. Tap once to reveal controls."
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="18" />
        </Border>

        <Grid Padding="20"
              RowDefinitions="Auto,*,Auto"
              RowSpacing="16"
              IsVisible="{Binding IsChromeVisible}">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="14"
                  MaximumWidthRequest="1100"
                  HorizontalOptions="Center">
                <Button Text="Back"
                        Command="{Binding BackCommand}"
                        BackgroundColor="#D91A1A1A"
                        TextColor="White"
                        CornerRadius="20"
                        Padding="18,12"
                        MinimumHeightRequest="52" />

                <Border Grid.Column="1"
                        BackgroundColor="#D91A1A1A"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">
                    <Label Text="{Binding StatusText}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="17"
                           Padding="18,12"
                           MaxLines="2" />
                </Border>

                <Button Grid.Column="2"
                        Text="{Binding LockButtonText}"
                        Command="{Binding ToggleLockCommand}"
                        BackgroundColor="#D91A1A1A"
                        TextColor="White"
                        CornerRadius="20"
                        Padding="18,12"
                        MinimumHeightRequest="52"
                        MinimumWidthRequest="132"
                        IsVisible="{Binding CanShowEditControls}" />

                <Border Grid.Column="2"
                        BackgroundColor="#D91A1A1A"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        IsVisible="{Binding IsUnlockPanelVisible}"
                        Padding="18,12">
                    <Label Text="Locked"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="16" />
                </Border>
            </Grid>

            <VerticalStackLayout Grid.Row="2"
                                 Spacing="12"
                                 MaximumWidthRequest="760"
                                 HorizontalOptions="Center">
                <Border BackgroundColor="#D91A1A1A"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24">
                    <Label Text="{Binding LockStatusText}"
                           TextColor="White"
                           Padding="18,12"
                           HorizontalTextAlignment="Center" />
                </Border>

                <Border BackgroundColor="#D91A1A1A"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 30"
                        IsVisible="{Binding CanShowEditControls}">
                    <ScrollView>
                        <VerticalStackLayout Padding="22"
                                             Spacing="20">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Brightness"
                                       TextColor="White"
                                       FontAttributes="Bold" />
                                <Label Grid.Column="1"
                                       Text="{Binding Brightness, StringFormat='{0:P0}'}"
                                       TextColor="White" />
                            </Grid>

                            <Slider Minimum="0.05"
                                    Maximum="1"
                                    Value="{Binding Brightness}"
                                    ThumbColor="#F5E7A1"
                                    MinimumTrackColor="#F5E7A1"
                                    MaximumTrackColor="#4A4A4A"
                                    HeightRequest="40" />

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="White Temperature"
                                       TextColor="White"
                                       FontAttributes="Bold" />
                                <Label Grid.Column="1"
                                       Text="{Binding ColorTemperature, StringFormat='{0:0}K'}"
                                       TextColor="White" />
                            </Grid>

                            <Slider Minimum="2700"
                                    Maximum="9000"
                                    Value="{Binding ColorTemperature}"
                                    IsEnabled="{Binding CanAdjustColorTemperature}"
                                    ThumbColor="#F5E7A1"
                                    MinimumTrackColor="#F5E7A1"
                                    MaximumTrackColor="#4A4A4A"
                                    HeightRequest="40" />

                            <Label Text="Presets"
                                   TextColor="White"
                                   FontAttributes="Bold" />

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12"
                                  RowDefinitions="Auto,Auto"
                                  RowSpacing="12">
                                <Button Text="White"
                                        Command="{Binding SelectPresetCommand}"
                                        CommandParameter="White"
                                        BackgroundColor="{Binding WhitePresetBackground}"
                                        TextColor="{Binding WhitePresetTextColor}"
                                        CornerRadius="22"
                                        MinimumHeightRequest="48" />

                                <Button Grid.Column="1"
                                        Text="Warm"
                                        Command="{Binding SelectPresetCommand}"
                                        CommandParameter="Warm"
                                        BackgroundColor="{Binding WarmPresetBackground}"
                                        TextColor="{Binding WarmPresetTextColor}"
                                        CornerRadius="22"
                                        MinimumHeightRequest="48" />

                                <Button Grid.Row="1"
                                        Text="Cool"
                                        Command="{Binding SelectPresetCommand}"
                                        CommandParameter="Cool"
                                        BackgroundColor="{Binding CoolPresetBackground}"
                                        TextColor="{Binding CoolPresetTextColor}"
                                        CornerRadius="22"
                                        MinimumHeightRequest="48" />

                                <Button Grid.Row="1"
                                        Grid.Column="1"
                                        Text="Custom"
                                        Command="{Binding SelectPresetCommand}"
                                        CommandParameter="Custom"
                                        BackgroundColor="{Binding CustomPresetBackground}"
                                        TextColor="{Binding CustomPresetTextColor}"
                                        CornerRadius="22"
                                        MinimumHeightRequest="48" />
                            </Grid>

                            <VerticalStackLayout Spacing="10"
                                                 IsVisible="{Binding CanEditCustomColor}">
                                <Label Text="Custom Hex Colour"
                                       TextColor="White"
                                       FontAttributes="Bold" />

                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <Entry Text="{Binding CustomColorHexInput}"
                                           Placeholder="#FFFFFF"
                                           TextColor="White"
                                           PlaceholderColor="#CCFFFFFF"
                                           BackgroundColor="#26000000"
                                           ClearButtonVisibility="WhileEditing"
                                           ReturnType="Done"
                                           HeightRequest="48" />

                                    <Button Grid.Column="1"
                                            Text="Apply"
                                            Command="{Binding ApplyCustomColorCommand}"
                                            BackgroundColor="#F5E7A1"
                                            TextColor="Black"
                                            CornerRadius="22"
                                            MinimumHeightRequest="48"
                                            Padding="18,12" />
                                </Grid>

                                <Label Text="{Binding AppliedCustomColorHex}"
                                       TextColor="White"
                                       FontSize="12" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>
                </Border>

                <Border BackgroundColor="#D91A1A1A"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 30"
                        IsVisible="{Binding IsUnlockPanelVisible}">
                    <VerticalStackLayout Padding="22"
                                         Spacing="14">
                        <Label Text="Unlock requires a press-and-hold so incidental taps do not reopen editing."
                               TextColor="White"
                               HorizontalTextAlignment="Center" />

                        <Button Text="{Binding UnlockButtonText}"
                                Pressed="OnUnlockButtonPressed"
                                Released="OnUnlockButtonReleased"
                                Unloaded="OnUnlockButtonUnloaded"
                                BackgroundColor="#F5E7A1"
                                TextColor="Black"
                                CornerRadius="24"
                                MinimumHeightRequest="52"
                                Padding="18,12" />

                        <ProgressBar Progress="{Binding UnlockProgress}"
                                     ProgressColor="#F5E7A1"
                                     BackgroundColor="#4A4A4A"
                                     HeightRequest="10" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
