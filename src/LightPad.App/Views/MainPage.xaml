<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:LightPad.App.ViewModels"
             x:Class="LightPad.App.Views.MainPage"
             x:DataType="viewModels:MainViewModel"
             Title="LightPad"
             BackgroundColor="#F4EBDD">

    <Grid RowDefinitions="Auto,*">
        <Grid Padding="24,32,24,22">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1">
                    <GradientStop Color="#F8F1E8"
                                  Offset="0.0" />
                    <GradientStop Color="#E7D8C0"
                                  Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
            <VerticalStackLayout Spacing="10">
                <Border BackgroundColor="#FFF7EE"
                        Stroke="#D8C2A4"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="10,6"
                        HorizontalOptions="Start">
                    <Label Text="DIGITAL LIGHTBOX"
                           TextColor="#7A5B34"
                           FontSize="12"
                           FontAttributes="Bold" />
                </Border>

                <Label Text="LightPad"
                       FontSize="34"
                       FontAttributes="Bold"
                       TextColor="#24160D" />

                <Label Text="Tracing, reference alignment, and animation planning in one workspace."
                       TextColor="#5E4B3B"
                       FontSize="16"
                       MaximumWidthRequest="420" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,18,20,24"
                                 Spacing="16">
                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="16"
                      RowSpacing="16">
                    <Border Grid.Row="0"
                            Grid.Column="0"
                            BackgroundColor="#FFF9F2"
                            Stroke="#D8C4AA"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 28"
                            MinimumHeightRequest="178"
                            Padding="18">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLightboxCommand}" />
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Border BackgroundColor="#F5E7A1"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    HeightRequest="56"
                                    WidthRequest="56"
                                    HorizontalOptions="Start">
                                <Image Source="icon_lightbox.svg"
                                       HeightRequest="28"
                                       WidthRequest="28"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Row="1"
                                                 Spacing="8"
                                                 VerticalOptions="End">
                                <Label Text="Plain Lightbox"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#24160D" />
                                <Label Text="Full-screen light surface with brightness and colour controls."
                                       TextColor="#6D5846"
                                       FontSize="14" />
                            </VerticalStackLayout>

                            <Label Grid.Row="2"
                                   Text="Open mode"
                                   TextColor="#8B6A43"
                                   FontAttributes="Bold"
                                   FontSize="13" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            BackgroundColor="#FFF9F2"
                            Stroke="#D8C4AA"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 28"
                            MinimumHeightRequest="178"
                            Padding="18">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenTraceImageCommand}" />
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Border BackgroundColor="#E8C7A5"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    HeightRequest="56"
                                    WidthRequest="56"
                                    HorizontalOptions="Start">
                                <Image Source="icon_trace.svg"
                                       HeightRequest="28"
                                       WidthRequest="28"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Row="1"
                                                 Spacing="8"
                                                 VerticalOptions="End">
                                <Label Text="Trace Image"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#24160D" />
                                <Label Text="Import a reference image, then pan, zoom, and fade it for tracing."
                                       TextColor="#6D5846"
                                       FontSize="14" />
                            </VerticalStackLayout>

                            <Label Grid.Row="2"
                                   Text="Open mode"
                                   TextColor="#8B6A43"
                                   FontAttributes="Bold"
                                   FontSize="13" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            BackgroundColor="#FFF9F2"
                            Stroke="#D8C4AA"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 28"
                            MinimumHeightRequest="178"
                            Padding="18">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenAnimationFramesCommand}" />
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Border BackgroundColor="#C9D9C0"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    HeightRequest="56"
                                    WidthRequest="56"
                                    HorizontalOptions="Start">
                                <Image Source="icon_animation.svg"
                                       HeightRequest="28"
                                       WidthRequest="28"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Row="1"
                                                 Spacing="8"
                                                 VerticalOptions="End">
                                <Label Text="Animation Frames"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#24160D" />
                                <Label Text="Build a frame sequence and compare motion with onion-skin overlays."
                                       TextColor="#6D5846"
                                       FontSize="14" />
                            </VerticalStackLayout>

                            <Label Grid.Row="2"
                                   Text="Open mode"
                                   TextColor="#8B6A43"
                                   FontAttributes="Bold"
                                   FontSize="13" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            BackgroundColor="#FFF9F2"
                            Stroke="#D8C4AA"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 28"
                            MinimumHeightRequest="178"
                            Padding="18">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenSettingsCommand}" />
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Border BackgroundColor="#D9D8EC"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    HeightRequest="56"
                                    WidthRequest="56"
                                    HorizontalOptions="Start">
                                <Image Source="icon_settings.svg"
                                       HeightRequest="28"
                                       WidthRequest="28"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Row="1"
                                                 Spacing="8"
                                                 VerticalOptions="End">
                                <Label Text="Settings"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#24160D" />
                                <Label Text="Adjust default brightness, colour temperature, and tracing preferences."
                                       TextColor="#6D5846"
                                       FontSize="14" />
                            </VerticalStackLayout>

                            <Label Grid.Row="2"
                                   Text="Open mode"
                                   TextColor="#8B6A43"
                                   FontAttributes="Bold"
                                   FontSize="13" />
                        </Grid>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
