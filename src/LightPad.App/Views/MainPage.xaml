<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:LightPad.App.ViewModels"
             x:Class="LightPad.App.Views.MainPage"
             x:DataType="viewModels:MainViewModel"
             Title="LightPad">

    <VerticalStackLayout Padding="24" Spacing="12">
        <Label Text="LightPad"
               FontSize="28"
               HorizontalOptions="Center"
               FontAttributes="Bold" />

        <Button Text="Plain Lightbox"
                Command="{Binding OpenLightboxCommand}" />

        <Button Text="Trace Image"
                Command="{Binding OpenTraceImageCommand}" />

        <Button Text="Animation Frames"
                Command="{Binding OpenAnimationFramesCommand}" />

        <Button Text="Settings"
                Command="{Binding OpenSettingsCommand}" />
    </VerticalStackLayout>

</ContentPage>
